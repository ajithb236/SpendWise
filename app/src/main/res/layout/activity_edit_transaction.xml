<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/navy_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">
            <ImageView
                android:id="@+id/btn_close"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/card_background"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="@color/text_primary"
                android:padding="10dp"
                android:clickable="true"
                android:focusable="true" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Edit Transaction"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
            <View
                android:layout_width="44dp"
                android:layout_height="44dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TYPE"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="8dp" />
        <Spinner
            android:id="@+id/spinner_type"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/input_background"
            android:paddingHorizontal="14dp"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MERCHANT"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="8dp" />
        <EditText
            android:id="@+id/et_merchant"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:hint="Merchant"
            android:background="@drawable/input_background"
            android:paddingHorizontal="14dp"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AMOUNT"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="8dp" />
        <EditText
            android:id="@+id/et_amount"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:hint="0.00"
            android:inputType="numberDecimal"
            android:background="@drawable/input_background"
            android:paddingHorizontal="14dp"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DATE (yyyy-MM-dd)"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="8dp" />
        <EditText
            android:id="@+id/et_date"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:hint="2026-03-27"
            android:background="@drawable/input_background"
            android:paddingHorizontal="14dp"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CATEGORY"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="8dp" />
        <Spinner
            android:id="@+id/spinner_category"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/input_background"
            android:paddingHorizontal="14dp"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PAYMENT METHOD"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="8dp" />
        <EditText
            android:id="@+id/et_payment_method"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:hint="UPI / CARD / CASH"
            android:background="@drawable/input_background"
            android:paddingHorizontal="14dp"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONFIDENCE SCORE"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="8dp" />
        <EditText
            android:id="@+id/et_confidence"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:hint="0.0 to 1.0"
            android:inputType="numberDecimal"
            android:background="@drawable/input_background"
            android:paddingHorizontal="14dp"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RAW SMS / NOTE"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="8dp" />
        <EditText
            android:id="@+id/et_raw_sms"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:hint="Raw SMS / Note"
            android:gravity="top"
            android:background="@drawable/input_background"
            android:padding="14dp"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INSTRUMENT TYPE"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="8dp" />
        <EditText
            android:id="@+id/et_instrument_type"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:hint="CARD / BANK / UPI"
            android:background="@drawable/input_background"
            android:paddingHorizontal="14dp"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INSTRUMENT ID"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="8dp" />
        <EditText
            android:id="@+id/et_instrument_id"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:hint="last4 / identifier"
            android:background="@drawable/input_background"
            android:paddingHorizontal="14dp"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INSTRUMENT REF ID"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="8dp" />
        <EditText
            android:id="@+id/et_instrument_ref_id"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:hint="linked instrument ref"
            android:background="@drawable/input_background"
            android:paddingHorizontal="14dp"
            android:layout_marginBottom="14dp" />

        <TextView
            android:id="@+id/tv_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/expense"
            android:textSize="13sp"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Changes"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/rounded_button_primary"
            android:padding="16dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>
</ScrollView>
